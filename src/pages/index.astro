---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// All series with full post list
const series = [
  {
    id: 'getting-started',
    emoji: '🚀',
    label: '入门启动',
    color: '#FF6B35',
    posts: [
      { title: 'OpenClaw 是什么？来龙去脉一次讲清楚', slug: '02-what-is-openclaw', desc: '为什么它突然火了？和 ChatGPT 有什么区别？' },
      { title: '5 分钟把它跑起来，最小闭环快速体验', slug: '03-5min-quickstart', desc: '跟着做，零基础也能 5 分钟跑起来' },
      { title: '核心概念：Gateway / Channel / Memory / Agent', slug: '04-concepts', desc: '听不懂的行话？这篇全部大白话讲透' },
    ],
  },
  {
    id: 'core-features',
    emoji: '🔧',
    label: '核心功能',
    color: '#4ECDC4',
    posts: [
      { title: '接起飞书 / Telegram，消息一发 AI 就动', slug: '05-connect-feishu-telegram', desc: '让它变成你每天真正在用的工具' },
      { title: '人格设定：SOUL.md / USER.md 怎么写', slug: '06-personality', desc: '让它像你肚子里的蛔虫，懂你' },
      { title: '记忆系统：它怎么记住你说的话', slug: '07-memory', desc: '分层记忆架构，越用越懂你' },
      { title: '定时任务：让它每天自动干活', slug: '08-auto-tasks', desc: '不用发消息，它自己会动' },
      { title: 'Skills 技能系统：ClawHub 安装与使用', slug: '09-skills', desc: '给它装插件，能力原地升级' },
    ],
  },
  {
    id: 'advanced',
    emoji: '🏗',
    label: '进阶应用',
    color: '#7B68EE',
    posts: [
      { title: '多智能体团队：一个 AI 变多个专业助理', slug: '10-multi-agent', desc: '各司其职，互相协作' },
      { title: '安全使用：这些坑一定要避开', slug: '11-security', desc: 'API Key 泄露、权限过大…踩过才懂' },
      { title: '开发自己的 Skill：从零手把手', slug: '12-custom-skill', desc: '让它做任何你想要的事' },
      { title: '实战案例：搭一套完整的 AI 个人助理系统', slug: '13-case-study', desc: '串联所有技能，真正每天在用' },
    ],
  },
];
---

<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <style>
    :global(html) { scroll-behavior: smooth; }
    body { font-family: var(--font-atkinson), sans-serif; }
    main { max-width: 1100px; margin: 0 auto; padding: 0 1.25rem; }

    /* ── Topbar ─────────────────────────────── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 0 1rem;
      border-bottom: 1px solid var(--bg-offset);
      margin-bottom: 2rem;
    }
    .topbar-brand {
      font-size: 1.6rem;
      font-weight: 700;
      text-decoration: none;
      color: inherit;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .topbar-brand span { font-size: 1.4rem; }
    .topbar-nav {
      display: flex;
      gap: 0.25rem;
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .topbar-nav li a {
      text-decoration: none;
      color: rgb(var(--gray-dark));
      font-size: 0.9rem;
      padding: 0.4rem 0.75rem;
      border-radius: 8px;
      transition: background 0.15s;
    }
    .topbar-nav li a:hover { background: var(--bg-offset); }
    .topbar-nav li a.active { color: rgb(var(--accent)); font-weight: 600; }

    /* ── Hero ───────────────────────────────── */
    .hero {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: center;
      padding: 2rem 0 2.5rem;
      border-bottom: 1px solid var(--bg-offset);
    }
    .hero-text h1 {
      font-size: clamp(2.2rem, 5vw, 3.2rem);
      margin: 0 0 0.5rem;
      letter-spacing: -0.03em;
      line-height: 1.1;
    }
    .hero-text h1 span { color: rgb(var(--accent)); }
    .hero-text .subtitle {
      font-size: 1.05rem;
      color: rgb(var(--gray));
      margin: 0 0 1.25rem;
      line-height: 1.6;
    }
    .hero-badges {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 1.25rem;
    }
    .hero-badges span {
      background: var(--bg-offset);
      padding: 0.3rem 0.75rem;
      border-radius: 20px;
      font-size: 0.8rem;
      color: rgb(var(--gray-dark));
    }
    .hero-badges span.highlight { background: rgb(var(--accent)); color: white; }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: rgb(var(--accent));
      color: white;
      padding: 0.7rem 1.4rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      transition: opacity 0.2s;
    }
    .hero-cta:hover { opacity: 0.88; }
    .hero-cta.secondary {
      background: transparent;
      color: rgb(var(--accent));
      border: 1.5px solid rgb(var(--accent));
    }
    .hero-aside {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      min-width: 220px;
    }
    .stat-card {
      background: var(--bg-offset);
      border-radius: 12px;
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }
    .stat-card .stat-num {
      font-size: 2rem;
      font-weight: 700;
      color: rgb(var(--accent));
      line-height: 1;
    }
    .stat-card .stat-label {
      font-size: 0.85rem;
      color: rgb(var(--gray-dark));
      line-height: 1.3;
    }

    /* ── Section Title ──────────────────────── */
    .section-title {
      font-size: 1.25rem;
      font-weight: 700;
      margin: 2.5rem 0 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--bg-offset);
      margin-left: 0.5rem;
    }

    /* ── All Tutorials ─────────────────────── */
    .tutorials-all {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }
    .tutorial-item {
      background: var(--bg-offset);
      border-radius: 10px;
      padding: 0.85rem 1rem;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      text-decoration: none;
      color: inherit;
      transition: transform 0.15s, box-shadow 0.15s;
      border: 1.5px solid transparent;
    }
    .tutorial-item:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.07);
      border-color: rgb(var(--accent));
    }
    .tutorial-item .t-emoji {
      font-size: 1.4rem;
      flex-shrink: 0;
      margin-top: 0.1rem;
    }
    .tutorial-item .t-body { flex: 1; min-width: 0; }
    .tutorial-item .t-title {
      font-size: 0.88rem;
      font-weight: 600;
      margin: 0 0 0.2rem;
      line-height: 1.3;
    }
    .tutorial-item:hover .t-title { color: rgb(var(--accent)); }
    .tutorial-item .t-desc {
      font-size: 0.78rem;
      color: rgb(var(--gray));
      margin: 0;
      line-height: 1.4;
    }

    /* ── Series Sections ───────────────────── */
    .series-block {
      margin-bottom: 1.5rem;
      border: 1px solid var(--bg-offset);
      border-radius: 14px;
      overflow: hidden;
    }
    .series-block-header {
      padding: 0.85rem 1.25rem;
      color: white;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .series-block-header .series-left {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .series-block-header .series-emoji { font-size: 1.5rem; }
    .series-block-header .series-label {
      font-weight: 700;
      font-size: 1rem;
    }
    .series-block-header .series-tagline {
      font-size: 0.8rem;
      opacity: 0.85;
    }
    .series-block-header .series-count {
      background: rgba(255,255,255,0.2);
      padding: 0.2rem 0.65rem;
      border-radius: 20px;
      font-size: 0.75rem;
    }
    .series-block-body { padding: 0.75rem; background: var(--bg-offset); }
    .series-posts {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 0.6rem;
    }
    .series-post a {
      background: white;
      border-radius: 8px;
      padding: 0.8rem 1rem;
      text-decoration: none;
      color: inherit;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      transition: all 0.15s;
      border: 1.5px solid transparent;
    }
    .series-post a:hover {
      border-color: currentColor;
      transform: translateY(-1px);
    }
    .series-post .sp-num {
      font-size: 0.7rem;
      font-weight: 700;
      opacity: 0.5;
      min-width: 1.4rem;
    }
    .series-post .sp-title {
      font-size: 0.85rem;
      line-height: 1.3;
    }
    .series-post a:hover .sp-title { color: rgb(var(--accent)); }

    /* ── Bottom CTA ────────────────────────── */
    .cta-bottom {
      background: linear-gradient(135deg, #1a1a2e, #16213e);
      border-radius: 14px;
      padding: 2rem;
      margin: 2rem 0 3rem;
      text-align: center;
      color: white;
    }
    .cta-bottom h3 {
      margin: 0 0 0.5rem;
      font-size: 1.5rem;
    }
    .cta-bottom p {
      margin: 0 0 1.5rem;
      opacity: 0.75;
      font-size: 0.95rem;
    }
    .cta-bottom a {
      display: inline-block;
      background: white;
      color: #1a1a2e;
      padding: 0.75rem 1.75rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      transition: opacity 0.2s;
    }
    .cta-bottom a:hover { opacity: 0.9; }

    /* ── Footer ────────────────────────────── */
    footer {
      text-align: center;
      padding: 2rem 0;
      color: rgb(var(--gray));
      font-size: 0.85rem;
      border-top: 1px solid var(--bg-offset);
    }
  </style>
</head>

<body>
  <main>

    <!-- Top Navigation -->
    <nav class="topbar">
      <a href="/" class="topbar-brand"><span>🦞</span> StudyClaw</a>
      <ul class="topbar-nav">
        <li><a href="/" class="active">首页</a></li>
        <li><a href="/blog">全部教程</a></li>
        <li><a href="/about">关于</a></li>
      </ul>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-text">
        <h1>OpenClaw <span>中文教程</span></h1>
        <p class="subtitle">
          从零开始，打造你的 AI 个人助理。<br/>
          零基础可学，5 分钟跑起来，真正能用的实战内容。
        </p>
        <div class="hero-badges">
          <span class="highlight">🆓 全部免费</span>
          <span>⚡ 5 分钟上手</span>
          <span>🔧 飞书 / Telegram 已接入</span>
          <span>📚 {series.reduce((s,g) => s + g.posts.length, 0)} 篇实战教程</span>
        </div>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="/blog" class="hero-cta">🚀 开始学习</a>
          <a href="/blog/03-5min-quickstart" class="hero-cta secondary">⚡ 5分钟跑起来 →</a>
        </div>
      </div>
      <div class="hero-aside">
        <div class="stat-card">
          <div class="stat-num">{series.reduce((s,g) => s + g.posts.length, 0)}</div>
          <div class="stat-label">篇实战教程<br/>全部免费</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">3</div>
          <div class="stat-label">阶段路径<br/>循序渐进</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">∞</div>
          <div class="stat-label">次使用<br/>无限制</div>
        </div>
      </div>
    </section>

    <!-- All Tutorials Quick View -->
    <h2 class="section-title">📖 全部教程 · {series.reduce((s,g) => s + g.posts.length, 0)} 篇</h2>

    <div class="tutorials-all">
      <a href="/blog/02-what-is-openclaw" class="tutorial-item">
        <span class="t-emoji">🚀</span>
        <div class="t-body">
          <p class="t-title">OpenClaw 是什么？来龙去脉一次讲清楚</p>
          <p class="t-desc">为什么它突然火了？和 ChatGPT 有什么区别？</p>
        </div>
      </a>
      <a href="/blog/03-5min-quickstart" class="tutorial-item">
        <span class="t-emoji">⚡</span>
        <div class="t-body">
          <p class="t-title">5 分钟把它跑起来，最小闭环快速体验</p>
          <p class="t-desc">跟着做，零基础也能 5 分钟跑起来</p>
        </div>
      </a>
      <a href="/blog/04-concepts" class="tutorial-item">
        <span class="t-emoji">🧠</span>
        <div class="t-body">
          <p class="t-title">核心概念：Gateway / Channel / Memory / Agent</p>
          <p class="t-desc">听不懂的行话？这篇全部大白话讲透</p>
        </div>
      </a>
      <a href="/blog/05-connect-feishu-telegram" class="tutorial-item">
        <span class="t-emoji">🔧</span>
        <div class="t-body">
          <p class="t-title">接起飞书 / Telegram，消息一发 AI 就动</p>
          <p class="t-desc">让它变成你每天真正在用的工具</p>
        </div>
      </a>
      <a href="/blog/06-personality" class="tutorial-item">
        <span class="t-emoji">💬</span>
        <div class="t-body">
          <p class="t-title">人格设定：SOUL.md / USER.md 怎么写</p>
          <p class="t-desc">让它像你肚子里的蛔虫，懂你</p>
        </div>
      </a>
      <a href="/blog/07-memory" class="tutorial-item">
        <span class="t-emoji">🧩</span>
        <div class="t-body">
          <p class="t-title">记忆系统：它怎么记住你说的话</p>
          <p class="t-desc">分层记忆架构，越用越懂你</p>
        </div>
      </a>
      <a href="/blog/08-auto-tasks" class="tutorial-item">
        <span class="t-emoji">⏰</span>
        <div class="t-body">
          <p class="t-title">定时任务：让它每天自动干活</p>
          <p class="t-desc">不用发消息，它自己会动</p>
        </div>
      </a>
      <a href="/blog/09-skills" class="tutorial-item">
        <span class="t-emoji">🔌</span>
        <div class="t-body">
          <p class="t-title">Skills 技能系统：ClawHub 安装与使用</p>
          <p class="t-desc">给它装插件，能力原地升级</p>
        </div>
      </a>
      <a href="/blog/10-multi-agent" class="tutorial-item">
        <span class="t-emoji">👥</span>
        <div class="t-body">
          <p class="t-title">多智能体团队：一个 AI 变多个专业助理</p>
          <p class="t-desc">各司其职，互相协作</p>
        </div>
      </a>
      <a href="/blog/11-security" class="tutorial-item">
        <span class="t-emoji">🔒</span>
        <div class="t-body">
          <p class="t-title">安全使用：这些坑一定要避开</p>
          <p class="t-desc">API Key 泄露、权限过大…踩过才懂</p>
        </div>
      </a>
      <a href="/blog/12-custom-skill" class="tutorial-item">
        <span class="t-emoji">⚙️</span>
        <div class="t-body">
          <p class="t-title">开发自己的 Skill：从零手把手</p>
          <p class="t-desc">让它做任何你想要的事</p>
        </div>
      </a>
      <a href="/blog/13-case-study" class="tutorial-item">
        <span class="t-emoji">🚀</span>
        <div class="t-body">
          <p class="t-title">实战案例：搭一套完整的 AI 个人助理系统</p>
          <p class="t-desc">串联所有技能，真正每天在用</p>
        </div>
      </a>
    </div>

    <!-- Series Detail Blocks -->
    <h2 class="section-title">🗂 教程路径 · 分阶段学习</h2>

    {series.map((s) => (
      <div class="series-block">
        <div class="series-block-header" style={`background: ${s.color};`}>
          <div class="series-left">
            <span class="series-emoji">{s.emoji}</span>
            <div>
              <div class="series-label">{s.label}</div>
              <div class="series-tagline">{
                s.id === 'getting-started' ? '零基础，跟得上，扫除恐惧感' :
                s.id === 'core-features' ? '装好就用，真实有用的日常工具' :
                '解锁完整能力，从使用者变构建者'
              }</div>
            </div>
          </div>
          <span class="series-count">{s.posts.length} 篇</span>
        </div>
        <div class="series-block-body">
          <div class="series-posts">
            {s.posts.map((post, i) => (
              <div class="series-post">
                <a href={`/blog/${post.slug}`}>
                  <span class="sp-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="sp-title">{post.title}</span>
                </a>
              </div>
            ))}
          </div>
        </div>
      </div>
    ))}

    <!-- CTA -->
    <div class="cta-bottom">
      <h3>准备好开始了吗？</h3>
      <p>5 分钟跑起来，你的第一条 AI 消息，就从现在开始。</p>
      <a href="/blog/03-5min-quickstart">⚡ 立即开始 →</a>
    </div>

    <footer>
      <p>🦞 StudyClaw — OpenClaw 中文教程 · 完全免费 · 持续更新</p>
    </footer>

  </main>
  <Footer />
</body>
</html>
