---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.hero {
				text-align: center;
				padding: 4rem 0 3rem;
			}
			.hero h1 {
				font-size: 3rem;
				margin-bottom: 1rem;
				line-height: 1.2;
			}
			.hero .subtitle {
				font-size: 1.25rem;
				color: rgb(var(--gray));
				margin-bottom: 2rem;
				max-width: 600px;
				margin-left: auto;
				margin-right: auto;
			}
			.hero .cta {
				display: inline-block;
				background: rgb(var(--accent));
				color: white;
				padding: 0.75rem 1.5rem;
				border-radius: 8px;
				text-decoration: none;
				font-weight: bold;
				transition: opacity 0.2s;
			}
			.hero .cta:hover {
				opacity: 0.85;
			}
			.features {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1.5rem;
				margin: 3rem 0;
			}
			.feature {
				background: var(--bg-offset);
				border-radius: 12px;
				padding: 1.5rem;
			}
			.feature h3 {
				margin: 0 0 0.5rem;
				font-size: 1.1rem;
			}
			.feature p {
				color: rgb(var(--gray));
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.5;
			}
			.recent-posts {
				margin: 4rem 0 2rem;
			}
			.recent-posts h2 {
				font-size: 1.5rem;
				margin-bottom: 1.5rem;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				padding: 0.75rem 0;
				border-bottom: 1px solid var(--bg-offset);
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				color: inherit;
				text-decoration: none;
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
			}
			.post-list a:hover h4 {
				color: rgb(var(--accent));
			}
			.post-list h4 {
				margin: 0;
				font-weight: normal;
				font-size: 1rem;
			}
			.post-list .date {
				color: rgb(var(--gray));
				font-size: 0.85rem;
				white-space: nowrap;
			}
			.emoji {
				font-size: 1.2em;
				margin-right: 0.3em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>🧑🚀 StudyClaw</h1>
				<p class="subtitle">
					OpenClaw（小龙虾）中文教程 — 从零开始，打造你的 AI 个人助理。
					不炒概念，只讲能跑起来的实战。
				</p>
				<a href="/blog" class="cta">开始学习 →</a>
			</section>

			<section class="features">
				<div class="feature">
					<h3>⚡ 快速上手</h3>
					<p>5 分钟跑起来，不用懂代码也能装好。</p>
				</div>
				<div class="feature">
					<h3>🧠 深入原理</h3>
					<p>Gateway / Memory / Skills / Agent，核心概念全讲透。</p>
				</div>
				<div class="feature">
					<h3>🔧 拿来就用</h3>
					<p>飞书接入、定时任务、搜索技能，全部配好。</p>
				</div>
				<div class="feature">
					<h3>🔒 安全第一</h3>
					<p>API Key 管理、权限控制、避坑指南。</p>
				</div>
			</section>

			<section class="recent-posts">
				<h2>📖 最新文章</h2>
				<ul class="post-list">
					<li>
						<a href="/blog/13-case-study">
							<h4>🚀 实战案例：用 OpenClaw 搭一套我的 AI 个人助理系统</h4>
							<span class="date">2026-05-11</span>
						</a>
					</li>
					<li>
						<a href="/blog/12-custom-skill">
							<h4>⚙️ 开发自己的 Skill：让 OpenClaw 做任何你想要的事</h4>
							<span class="date">2026-05-11</span>
						</a>
					</li>
					<li>
						<a href="/blog/11-security">
							<h4>🔒 安全使用 OpenClaw：这些坑一定要避开</h4>
							<span class="date">2026-05-11</span>
						</a>
					</li>
					<li>
						<a href="/blog/10-multi-agent">
							<h4>👥 多智能体团队：多个助手协作</h4>
							<span class="date">2026-05-11</span>
						</a>
					</li>
				</ul>
				<p style="margin-top:1rem; text-align:right;">
					<a href="/blog">查看全部文章 →</a>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
